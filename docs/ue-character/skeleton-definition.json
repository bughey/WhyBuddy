    "validation": {
      "rules": [
        {
          "id": "SKEL_001",
          "description": "Root bone must be at world origin (0, 0, 0)",
          "severity": "error"
        },
        {
          "id": "SKEL_002",
          "description": "All symmetric bones must have matching _L and _R counterparts",
          "severity": "error"
        },
        {
          "id": "SKEL_003",
          "description": "Total triangle count must not exceed maxTriangles (5000)",
          "severity": "error"
        },
        {
          "id": "SKEL_004",
          "description": "Bone names must follow PascalCase_Number convention",
          "severity": "warning"
        },
        {
          "id": "SKEL_005",
          "description": "Each IK chain root and end effector must exist in boneHierarchy",
          "severity": "error"
        },
        {
          "id": "SKEL_006",
          "description": "Pelvis must be positioned at character center of mass",
          "severity": "warning"
        }
      ]
    }

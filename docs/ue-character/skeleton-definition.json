      "skeleton": "SK_{CharacterType}_Skeleton",
      "skeletalMesh": "SM_{CharacterName}",
      "animationSequence": "AS_{CharacterType}_{ActionName}",
      "animationBlueprint": "ABP_{CharacterType}",
      "physicsAsset": "PA_{CharacterType}",
      "ikRig": "IKRig_{CharacterType}"

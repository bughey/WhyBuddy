      "spine": ["Root", "Pelvis", "Spine_01", "Spine_02"],
      "head": ["Neck", "Head", "Eye_L", "Eye_R", "Jaw"],
      "armLeft": [
        "Clavicle_L",
        "UpperArm_L",
        "LowerArm_L",
        "Hand_L",
        "Index_01_L",
        "Thumb_01_L"
      ],
      "armRight": [
